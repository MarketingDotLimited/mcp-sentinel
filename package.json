{
  "name": "mcp-sentinel",
  "version": "1.0.0",
  "description": "Secure MCP Server for remote server control via AI cloud services",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "setup": "node setup.js",
    "keygen": "node keygen.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 --reporter=html --reporter=text node --test tests/*.test.js",
    "test:live": "RUN_LIVE_E2E=true node --test tests/live-mcp-e2e.test.js",
    "test:ui": "RUN_UI_E2E=true node --test tests/ui-e2e.test.js",
    "update:authelia": "./scripts/update-authelia.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1092.0",
    "@modelcontextprotocol/sdk": "^1.25.4",
    "acme-client": "^5.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.4",
    "js-yaml": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.23.1",
    "pg": "^8.22.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.0"
  },
  "overrides": {
    "@hono/node-server": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/compression": "^1.8.1",
    "c8": "^12.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.6"
  }
}
