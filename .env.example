# ============================================================
#  MCP Sentinel - Environment Configuration
#  Copy this to .env and fill in your values
# ============================================================

# Server
PORT=4444
HOST=127.0.0.1
NODE_ENV=production

# TLS/HTTPS (production: use Let's Encrypt or trusted CA. Self-signed is for development only)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
USE_HTTPS=true

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_64_CHARS_MIN
JWT_EXPIRY=8h

# Master Admin API Key (generate with: node keygen.js)
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_KEYGEN

# IP Whitelist (comma-separated CIDRs or IPs, empty = allow all with key)
# Example: 203.0.113.10,192.168.1.0/24
ALLOWED_IPS=

# Proxy: set to true ONLY if behind a trusted reverse proxy (nginx, cloudflare) that sets X-Forwarded-For. Otherwise, spoofing is possible!
TRUST_PROXY=false
TRUSTED_PROXIES=127.0.0.1/32,::1/128

# CORS: comma-separated allowed origins (empty = allow all)
ALLOWED_ORIGINS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=120

# Connection Limits
MAX_SSE_CONNECTIONS=100

# Audit Log
AUDIT_LOG_DIR=./logs
AUDIT_LOG_KEEP_DAYS=30
AUDIT_HMAC_KEY=CHANGE_ME_64_HEX_CHARACTERS
AUDIT_CHECKPOINT_FILE=/var/lib/mcp-sentinel/audit-chain.json
JWT_REVOCATION_FILE=/var/lib/mcp-sentinel/jwt-revocations.json

# Max command output size in bytes
MAX_OUTPUT_SIZE=1048576

# Comma-separated project roots where the constrained run_project_tests tool may run.
PROJECT_ALLOWED_ROOTS=/srv/my-app,/srv/another-app
GIT_ALLOWED_REPOS=/srv/my-app,/srv/another-app

# OAuth runtime files live outside the checkout and must be mode 0600.
AUTHELIA_USERS_FILE=/etc/mcp-sentinel/users.yml
AUTHELIA_CONFIG_FILE=/etc/mcp-sentinel/authelia.yml
AUTHELIA_MAPPINGS_FILE=/etc/mcp-sentinel/user-mappings.json
AUTHELIA_BACKUP_DIR=/var/lib/mcp-sentinel/authelia-backups
OAUTH_RESOURCE_URL=https://mcp.example.com
AUTHELIA_ISSUER=https://auth.example.com
AUTHELIA_JWKS_URL=https://auth.example.com/jwks.json

# Legacy enterprise actions are absent from tools/list unless explicitly enabled
# for a time-bounded export window.
ENABLE_LEGACY_TOOLS=false

# Durable single-host state. SQLite runs in WAL mode and migrates a legacy
# CONTROL_PLANE_STATE_FILE once when this database is empty.
MCP_STATE_DB=/var/lib/mcp-sentinel/state.sqlite3
CONTROL_PLANE_STATE_FILE=/var/lib/mcp-sentinel/control-plane.json
CONTROL_PLANE_KEY_ID=state-key-v1
# Development fallback only; production loads the state-key systemd credential.
CONTROL_PLANE_ENCRYPTION_KEY=
DB_CONFIG_FILE=/etc/mcp-sentinel/databases.json
DB_CA_ROOT=/etc/mcp-sentinel/database-ca

# Rootless, digest-pinned OCI sandbox. Network access additionally requires
# SANDBOX_ALLOW_NETWORK=true, a preconfigured egress-filtered network, and a
# per-request confirm=true. Keep private/link-local/metadata routes blocked on
# that network outside this process.
SANDBOX_RUNTIME=podman
SANDBOX_IMAGE_PYTHON=registry.example.com/mcp/python@sha256:CHANGE_ME_64_HEX_DIGEST
SANDBOX_IMAGE_NODE=registry.example.com/mcp/node@sha256:CHANGE_ME_64_HEX_DIGEST
SANDBOX_SECCOMP_PROFILE=/etc/mcp-sentinel/sandbox/seccomp.json
SANDBOX_APPARMOR_PROFILE=mcp-sentinel-sandbox
SANDBOX_ALLOW_NETWORK=false
SANDBOX_NETWORK=
SANDBOX_ALLOW_DOCKER=false
