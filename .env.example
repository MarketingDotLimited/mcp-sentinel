# ============================================================
#  MCP Sentinel - Environment Configuration
#  Copy this to .env and fill in your values
# ============================================================

# Server
PORT=4444
HOST=0.0.0.0
NODE_ENV=production

# TLS/HTTPS (production: use Let's Encrypt or trusted CA. Self-signed is for development only)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
USE_HTTPS=true

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_64_CHARS_MIN
JWT_EXPIRY=8h

# Master Admin API Key (generate with: node keygen.js)
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_KEYGEN

# IP Whitelist (comma-separated CIDRs or IPs, empty = allow all with key)
# Example: 203.0.113.10,192.168.1.0/24
ALLOWED_IPS=

# Proxy: set to true ONLY if behind a trusted reverse proxy (nginx, cloudflare) that sets X-Forwarded-For. Otherwise, spoofing is possible!
TRUST_PROXY=false

# CORS: comma-separated allowed origins (empty = allow all)
ALLOWED_ORIGINS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Connection Limits
MAX_SSE_CONNECTIONS=100

# Audit Log
AUDIT_LOG_DIR=./logs
AUDIT_LOG_KEEP_DAYS=30

# Max command output size in bytes
MAX_OUTPUT_SIZE=1048576
