# ============================================================
#  MCP Server - Environment Configuration
#  Copy this to .env and fill in your values
# ============================================================

# Server
PORT=4444
HOST=0.0.0.0
NODE_ENV=production

# TLS/HTTPS (recommended: use Let's Encrypt or self-signed)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
USE_HTTPS=true

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_64_CHARS_MIN
JWT_EXPIRY=8h

# Master Admin API Key (generate with: node keygen.js)
ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_KEYGEN

# IP Whitelist (comma-separated CIDRs or IPs, empty = allow all with key)
# Example: 203.0.113.10,192.168.1.0/24
ALLOWED_IPS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Audit Log
AUDIT_LOG_DIR=./logs
AUDIT_LOG_KEEP_DAYS=30

# Command Security - Blacklisted commands (comma-separated, applies to non-admin)
BLACKLISTED_COMMANDS=rm -rf /,mkfs,dd if=,fork bomb,:(){ :|:& };:

# Max command output size in bytes
MAX_OUTPUT_SIZE=1048576

# Allowed sudo users (comma-separated usernames that can use sudo via MCP)
SUDO_ALLOWED_USERS=root
