NODE_ENV=production
HOST=127.0.0.1
PORT=4444
USE_HTTPS=false
PUBLIC_URL=https://mcp.example.com
ALLOWED_ORIGINS=https://mcp.example.com
TRUST_PROXY=true
TRUSTED_PROXIES=127.0.0.1/32,::1/128
OAUTH_RESOURCE_URL=https://mcp.example.com
AUTHELIA_ISSUER=https://auth.example.com
AUTHELIA_JWKS_URL=https://auth.example.com/jwks.json
MCP_STATE_DB=/var/lib/mcp-sentinel/state.sqlite3
CONTROL_PLANE_KEY_ID=state-v1
MCP_BROKER_SOCKET=/run/mcp-sentinel/broker.sock
MCP_SSH_RUNTIME_DIR=/run/mcp-sentinel/ssh
MCP_SSH_CREDENTIAL_DIR=/etc/mcp-sentinel/ssh-credentials
AUDIT_LOG_DIR=/var/log/mcp-sentinel
AUDIT_CHECKPOINT_FILE=/var/lib/mcp-sentinel/audit-chain.json
AUDIT_VERIFICATION_STATUS_FILE=/var/lib/mcp-sentinel/audit-verification.json
DB_CONFIG_FILE=/etc/mcp-sentinel/databases.json
MCP_POLICY_FILE=/run/credentials/mcp-sentinel.service/policy.json
JWT_EXPIRY=8h
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_MS=60000
TOOL_MAX_OUTPUT=5242880
TOOL_MAX_WALL_TIME=60
