MCP_BROKER_SOCKET=/run/mcp-sentinel/broker.sock
BROKER_MANAGED_SERVICES=example-app
BROKER_PROTECTED_SERVICES=mcp-sentinel,mcp-sentinel-broker,ssh,sshd,nginx,authelia
BROKER_FIREWALL_PORTS=22,443
BROKER_MANAGEMENT_PORTS=22,443
BROKER_MAX_OUTPUT_BYTES=5242880
MCP_STATE_DB=/var/lib/mcp-sentinel/state.sqlite3
BROKER_MANAGED_USERS=example-app-user
BROKER_MANAGED_GROUPS=example-app-group
BROKER_ALLOWED_SHELLS=/bin/bash,/bin/sh,/usr/sbin/nologin
BROKER_CONFIG_REGISTRY=/etc/mcp-sentinel/config-registry.json
BROKER_CONFIG_BACKUP_ROOT=/var/lib/mcp-sentinel/config-backups
BROKER_GIT_ALLOWED_REPOS=/var/www/vhosts/rabeeb.com/httpdocs
BROKER_FIREWALL_SNAPSHOT_ROOT=/var/lib/mcp-sentinel/firewall-snapshots
BROKER_FIREWALL_ROLLBACK_SCRIPT=/opt/mcp-sentinel/scripts/firewall-rollback.js
AUTHELIA_USERS_FILE=/etc/mcp-sentinel/users.yml
AUTHELIA_CONFIG_FILE=/etc/mcp-sentinel/authelia.yml
AUTHELIA_MAPPINGS_FILE=/etc/mcp-sentinel/user-mappings.json
AUTHELIA_BACKUP_DIR=/var/lib/mcp-sentinel/authelia-backups
AUTHELIA_ISSUER=https://auth.example.com
AUTHELIA_JWKS_URL=https://auth.example.com/jwks.json
OAUTH_RESOURCE_URL=https://mcp.example.com
